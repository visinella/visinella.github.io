---
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Hero from "~/components/Hero.astro";
import { Picture } from "astro:assets";
import ButtonCallUs from "~/components/ButtonCallUs.astro";
import Heading from "~/components/Heading.astro";
import ProductSlider from "~/components/ProductSlider.astro";

// Images
import CherryJarOpened from "~/assets/images/products/cherry-jar-opened.jpg";
---

<Layout title="Visinella" pageTitle="Visinella" description="Welcome to Visinella!">
	<Section id="home" class:list={"pt-[60px] lg:pt-[80px]"} style="scroll-margin-top: 120px;">
		<Hero>
			<div slot="hero-content-left" class="prose max-w-none max-lg:order-1">
				<h3 class="font-black">Produse naturale din livada noastră.</h3>

				<p>
					Suntem un producător dedicat realizării de produse naturale, din vișine culese cu grijă din propria livadă.
					Prin marca Visinella, ne propunem să aducem un gust autentic și sănătos în fiecare casă, oferind compoturi,
					gemuri și alte delicii realizate fără conservanți sau aditivi artificiali.
				</p>

				<span class="text-brand-red-dark font-medium">✔ Facem și livrare</span>

				<div class="mt-8 flex items-center gap-x-8">
					<ButtonCallUs />
				</div>
			</div>
			<div slot="hero-content-right">
				<Picture
					class:list={"clip-blob w-120 h-120 object-cover shadow-lg mx-auto"}
					src={CherryJarOpened}
					height={600}
					formats={["avif", "webp"]}
					alt="A description of my image."
					loading={"eager"}
					fetchpriority={"high"}
				/>
			</div>
		</Hero>
	</Section>
	<Section id="products" class:list={""} style="background-color: #fef5f5 !important; min-height: 100%;">
		<Heading>
			<h2 slot="heading-title" class="font-black text-brand-red-dark h2">Produsele noastre</h2>
			<p slot="heading-content">
				Descoperă produse naturale din vișine, realizate cu pasiune și grijă pentru
				calitate.
			</p>
		</Heading>

		<ProductSlider />
	</Section>
	<Section id="reviews" class:list={"bg-brand-red/20 relative"} style="background-color: rgba(122, 21, 37, 0.2) !important;">
		<div class="py-16">

		</div>

		<svg
			xmlns="http://www.w3.org/2000/svg"
			viewBox="0 0 1440 320"
			class="absolute h-40 w-full top-0 inset-x-0 rotate-180"
			preserveAspectRatio="none"
			><path
				fill="#ffffff"
				fill-opacity="1"
				d="M0,288L48,272C96,256,192,224,288,197.3C384,171,480,149,576,165.3C672,181,768,235,864,250.7C960,267,1056,245,1152,250.7C1248,256,1344,288,1392,304L1440,320L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"
			></path>
		</svg>
		<svg
			xmlns="http://www.w3.org/2000/svg"
			viewBox="0 0 1440 320"
			class="absolute h-40 w-full bottom-0 inset-x-0"
			preserveAspectRatio="none"
			><path
				fill="#ffffff"
				fill-opacity="1"
				d="M0,288L48,272C96,256,192,224,288,197.3C384,171,480,149,576,165.3C672,181,768,235,864,250.7C960,267,1056,245,1152,250.7C1248,256,1344,288,1392,304L1440,320L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"
			></path>
		</svg>
	</Section>
</Layout>
