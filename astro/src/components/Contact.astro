---
import { phone, email, whatsapp, telegram, address } from "~/data/config";
import IconPhone from "~/assets/icons/phone.svg";

// Format full address (filter out empty fields)
const addressParts = [address.street, address.city, address.zip, address.state, address.country].filter(part => part && part.trim() !== '');
const fullAddress = addressParts.join(', ');
// Google Maps embed URL (no API key needed for basic embed)
// If coordinates are available, use them; otherwise use address search
const mapsEmbedUrl = address.coordinates 
	? `https://www.google.com/maps?q=${address.coordinates}&output=embed`
	: `https://www.google.com/maps?q=${encodeURIComponent(fullAddress)}&output=embed`;
---

<div class="container mt-8">
	<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
		<!-- Map -->
		<div class="w-full h-[400px] lg:h-[500px] rounded-lg overflow-hidden shadow-lg">
			<iframe
				class="w-full h-full border-0"
				src={mapsEmbedUrl}
				allowfullscreen
				loading="lazy"
				referrerpolicy="no-referrer-when-downgrade"
				title="Location Map"
			></iframe>
		</div>

		<!-- Contact Information -->
		<div class="flex flex-col justify-center space-y-6">
			<div>
				<h3 class="text-2xl font-bold text-brand-red-dark mb-4">Date de contact</h3>
				<div class="space-y-4">
					<!-- Address -->
					<div class="flex items-start gap-3">
						<svg class="w-6 h-6 text-brand-red-dark flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
							<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
						</svg>
						<div>
							<p class="font-semibold text-gray-900">Adresă</p>
							<p class="text-gray-600">{fullAddress}</p>
						</div>
					</div>

					<!-- Phone -->
					<a href={phone.href} class="flex items-start gap-3 hover:text-brand-red-dark transition-colors">
						<IconPhone class="w-6 h-6 text-brand-red-dark flex-shrink-0 mt-1" />
						<div>
							<p class="font-semibold text-gray-900">Telefon</p>
							<p class="text-gray-600">{phone.label}</p>
						</div>
					</a>

					<!-- Email -->
					<a href={email.href} class="flex items-start gap-3 hover:text-brand-red-dark transition-colors">
						<svg class="w-6 h-6 text-brand-red-dark flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
						</svg>
						<div>
							<p class="font-semibold text-gray-900">Email</p>
							<p class="text-gray-600">{email.label}</p>
						</div>
					</a>

					<!-- WhatsApp -->
					<a href={whatsapp.href} target="_blank" rel="noopener noreferrer" class="flex items-start gap-3 hover:text-brand-red-dark transition-colors">
						<svg class="w-6 h-6 text-brand-red-dark flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 24 24">
							<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
						</svg>
						<div>
							<p class="font-semibold text-gray-900">WhatsApp</p>
							<p class="text-gray-600">{whatsapp.label}</p>
						</div>
					</a>

					<!-- Telegram -->
					<a href={telegram.href} target="_blank" rel="noopener noreferrer" class="flex items-start gap-3 hover:text-brand-red-dark transition-colors">
						<svg class="w-6 h-6 text-brand-red-dark flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 24 24">
							<path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
						</svg>
						<div>
							<p class="font-semibold text-gray-900">Telegram</p>
							<p class="text-gray-600">{telegram.label}</p>
						</div>
					</a>
				</div>
			</div>
		</div>
	</div>
</div>


