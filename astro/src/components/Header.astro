---
import { menuMain } from "~/data/menus.js";
import visinellaLogo from "~/assets/images/logo/visinella_logo-4x.png";
import PhoneNumber from "~/components/PhoneNumber.astro";
import CatalogButton from "~/components/CatalogButton.astro";

const rmTrailingSlash = (path: string): string => {
  return path.endsWith("/") && path.length > 1 
    ? path.slice(0, path.length - 1) 
    : path;
}

const pathname = rmTrailingSlash(Astro.url.pathname);
const isIndexPage = pathname === '/';
const currentHash = Astro.url.hash ? Astro.url.hash.substring(1) : (isIndexPage ? 'home' : null);
---

<header 
	{...({ 
		'x-data': '{ open: false, scrolled: false, initialized: false, activeSection: ' + (currentHash !== null ? '"' + currentHash + '"' : 'null') + ' }',
		'x-init': '$nextTick(() => { scrolled = window.scrollY > 50; initialized = true; if (window.location.pathname === "/" || window.location.pathname === "/index.html") { initActiveSectionObserver(); } })',
		'@keydown.window.escape': 'open = false',
		'@scroll.window': 'scrolled = window.scrollY > 50'
	} as any)}
	class="fixed top-0 left-0 right-0 z-[9999] bg-white"
	{...({ ':class': '{ "shadow-md": scrolled, "transition-all duration-300": initialized }' } as any)}
>
	<div class="container" {...({ ':class': '{ "transition-all duration-300": initialized, "py-3": scrolled, "py-6": !scrolled }' } as any)}>
		<nav class="flex items-center justify-between relative" aria-label="Global">
			<a href="/" class="-m-1.5 p-1.5 flex-shrink-0" {...({ ':class': '{ "transition-all duration-300": initialized }' } as any)}>
				<img 
					src={visinellaLogo.src} 
					alt="Visinella" 
					class="w-auto"
					{...({ ':class': '{ "transition-all duration-300": initialized, "h-12": scrolled, "h-28": !scrolled }' } as any)}
				/>
			</a>
			<div class="hidden lg:flex absolute left-1/2 -translate-x-1/2 z-10">
				<PhoneNumber />
			</div>
			<div class="flex lg:hidden">
				<button
					type="button"
					class="-m-2.5 inline-flex items-center justify-center rounded-md p-2.5"
					{...({ '@click': 'open = true' } as any)}
				>
					<span class="sr-only">Open main menu</span>
					<svg
						class="size-8 text-brand-red-dark"
						fill="none"
						viewBox="0 0 24 24"
						stroke-width="1.5"
						stroke="currentColor"
						aria-hidden="true"
						data-slot="icon"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
					</svg>
				</button>
			</div>
			<div class="hidden lg:flex lg:gap-x-12 lg:items-center">
				{
					menuMain.map((item) => {
						const isPdfLink = item.url.endsWith('.pdf');
						if (isPdfLink) {
							return <CatalogButton url={item.url} name={item.name} />;
						}
						return (
							<a
								href={item.url}
								{...({ '@click.prevent': `scrollToSection('${item.url}')` } as any)}
								class={`text-base/6 font-semibold rounded-full px-4 py-1.5 cursor-pointer ${item.highlighted ? "menu-item-highlighted" : ""}`}
								data-section={item.url.replace('/#', '')}
								{...({ ':class': '{ "menu-item-active": activeSection !== null && (activeSection === "' + item.url.replace('/#', '') + '" || (activeSection === "" && "' + item.url.replace('/#', '') + '" === "home")) }' } as any)}
							>
								{item.name}
							</a>
						);
					})
				}
			</div>
		</nav>
		<div class="lg:hidden" x-ref="dialog" x-show="open" x-cloak aria-modal="true">
			<div
				class="fixed inset-0 z-50 w-full overflow-y-auto bg-white px-8 py-6"
				x-show="open"
				x-transition:enter="transition ease-out"
				x-transition:enter-start="opacity-0"
				x-transition:enter-end="opacity-100"
				x-transition:leave="transition ease-in"
				x-transition:leave-start="opacity-100"
				x-transition:leave-end="opacity-0"
				x-cloak
			>
				<div class="flex items-center justify-between">
					<a href="/" class="-m-1.5 p-1.5">
						<img src={visinellaLogo.src} alt="Visinella" class="h-12 w-auto" />
					</a>
					<button type="button" class="-m-2.5 p-2.5 text-brand-red" {...({ '@click': 'open = false' } as any)}>
						<span class="sr-only">Close menu</span>
						<svg
							class="size-8"
							fill="none"
							viewBox="0 0 24 24"
							stroke-width="2"
							stroke="currentColor"
							aria-hidden="true"
							data-slot="icon"
						>
							<path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"></path>
						</svg>
					</button>
				</div>
				<div class="mt-6 flow-root">
					<div class="-my-6 divide-y divide-gray-500/10">
						<div class="space-y-2 py-6 mt-16">
							{
								menuMain.map((item) => {
									const isPdfLink = item.url.endsWith('.pdf');
									if (isPdfLink) {
										return (
											<div class="flex justify-center">
												<CatalogButton url={item.url} name={item.name} className="text-3xl" {...({ '@click': 'open = false' } as any)} />
											</div>
										);
									}
									return (
										<a
											href={item.url}
											{...({ '@click.prevent': `open = false; scrollToSection('${item.url}')` } as any)}
											class={`block py-2 text-center font-semibold text-3xl cursor-pointer rounded-full ${item.highlighted ? "menu-item-highlighted w-max mx-auto !px-8 !py-2" : ""}`}
											data-section={item.url.replace('/#', '')}
											{...({ ':class': '{ "menu-item-active": activeSection !== null && (activeSection === "' + item.url.replace('/#', '') + '" || (activeSection === "" && "' + item.url.replace('/#', '') + '" === "home")) }' } as any)}
										>
											{item.name}
										</a>
									);
								})
							}
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</header>

<script>
	/**
	 * Smoothly scrolls to a section on the page
	 * @param {string} url - URL with hash (e.g., "/#products")
	 */
	function scrollToSection(url: string) {
		if (!url.includes('#')) {
			window.location.href = url;
			return;
		}

		const hash = url.split('#')[1];
		const element = document.getElementById(hash);
		
		// If element doesn't exist (we're on a different page), navigate to index with hash
		if (!element) {
			window.location.href = url;
			return;
		}

		// If element exists, scroll to it
		const headerHeight = 100;
		const elementPosition = element.getBoundingClientRect().top;
		const offsetPosition = elementPosition + window.pageYOffset - headerHeight;

		window.scrollTo({
			top: offsetPosition,
			behavior: 'smooth'
		});
	}

	/**
	 * Handles smooth scroll on page load when URL contains a hash
	 */
	function handleHashOnLoad() {
		if (window.location.hash) {
			setTimeout(() => {
				const hash = window.location.hash.substring(1);
				const element = document.getElementById(hash);
				
				if (element) {
					const headerHeight = 100;
					const elementPosition = element.getBoundingClientRect().top;
					const offsetPosition = elementPosition + window.pageYOffset - headerHeight;
					
					window.scrollTo({
						top: offsetPosition,
						behavior: 'smooth'
					});
				}
			}, 100);
		}
	}

	/**
	 * Initializes IntersectionObserver to track active section
	 */
	function initActiveSectionObserver() {
		const sections = document.querySelectorAll('section[id]');
		const menuLinks = document.querySelectorAll('[href^="/#"]');
		let activeSectionId = '';
		
		const updateActiveSection = (sectionId: string) => {
			if (activeSectionId === sectionId) return;
			activeSectionId = sectionId;
			
			// Update Alpine.js activeSection
			const header = document.querySelector('header');
			if (header && (header as any).__x) {
				(header as any).__x.$data.activeSection = sectionId;
			}
			
			// Update active class on menu links
			menuLinks.forEach((link) => {
				const href = (link as HTMLAnchorElement).href;
				const linkHash = href.includes('#') ? href.split('#')[1] : '';
				if (linkHash === sectionId) {
					link.classList.add('menu-item-active');
				} else {
					link.classList.remove('menu-item-active');
				}
			});
		};
		
		const observer = new IntersectionObserver(
			(entries) => {
				// Find the section with the highest intersection ratio
				let maxRatio = 0;
				let mostVisibleSection = '';
				
				entries.forEach((entry) => {
					if (entry.isIntersecting && entry.intersectionRatio > maxRatio) {
						maxRatio = entry.intersectionRatio;
						mostVisibleSection = entry.target.id;
					}
				});
				
				// If we found a visible section, update active
				if (mostVisibleSection && maxRatio > 0.1) {
					updateActiveSection(mostVisibleSection);
				}
			},
			{ 
				threshold: [0, 0.1, 0.25, 0.5, 0.75, 1],
				rootMargin: '-120px 0px -60% 0px' 
			}
		);
		
		sections.forEach((section) => {
			observer.observe(section);
		});
		
		// Fallback: check on scroll which section is most visible
		let scrollTimeout: ReturnType<typeof setTimeout>;
		window.addEventListener('scroll', () => {
			clearTimeout(scrollTimeout);
			scrollTimeout = setTimeout(() => {
				let maxVisible = 0;
				let mostVisibleId = '';
				
				sections.forEach((section) => {
					const rect = section.getBoundingClientRect();
					const visibleHeight = Math.min(rect.bottom, window.innerHeight) - Math.max(rect.top, 0);
					const visibleRatio = visibleHeight / rect.height;
					
					if (visibleRatio > maxVisible && rect.top < window.innerHeight * 0.5) {
						maxVisible = visibleRatio;
						mostVisibleId = section.id;
					}
				});
				
				if (mostVisibleId) {
					updateActiveSection(mostVisibleId);
				}
			}, 100);
		});
	}

	// Make scrollToSection available globally for Alpine.js
	(window as any).scrollToSection = scrollToSection;
	(window as any).initActiveSectionObserver = initActiveSectionObserver;

	// Handle hash navigation on page load
	document.addEventListener('DOMContentLoaded', handleHashOnLoad);
</script>
