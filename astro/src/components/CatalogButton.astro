---
interface Props {
	url: string;
	name: string;
	className?: string;
	[key: string]: any; // Allow Alpine.js attributes
}

const { url, name, className = "", ...rest } = Astro.props;

// Determine icon size based on className (mobile uses text-3xl)
const isMobile = className.includes('text-3xl');
const iconSize = isMobile ? "w-6 h-6" : "w-4 h-4";
const baseClasses = isMobile 
	? "block py-2 text-center font-semibold text-3xl cursor-pointer rounded-full flex items-center justify-center gap-2 catalog-button w-max mx-auto !px-8 !py-2"
	: "text-base/6 font-semibold rounded-full px-4 py-1.5 cursor-pointer flex items-center gap-2 catalog-button";
---

<a
	href={url}
	target="_blank"
	rel="noopener noreferrer"
	class={`${baseClasses} ${className}`}
	{...rest}
>
	<svg class={iconSize} fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
		<path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
	</svg>
	{name}
</a>
